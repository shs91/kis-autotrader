# Streamlit secrets — 운영자가 cp 후 편집
#   cp dashboard/.streamlit/secrets.toml.example dashboard/.streamlit/secrets.toml
#
# 미설정 시 dashboard/app.py의 default 값(HEALTH_URL=18923) 사용.
# DB는 .env의 DATABASE_URL을 그대로 사용하거나 여기서 override 가능.

DATABASE_URL = "postgresql://kis_user:kis_password@localhost:5432/kis_trader"

# 매매 엔진 헬스체크 URL — 반드시 .env의 HEALTH_PORT와 일치해야 함 (기본 18923).
# 잘못된 포트면 대시보드가 OFFLINE으로 표시되므로 주의.
HEALTH_URL = "http://localhost:18923/health"
