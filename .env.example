# KIS API
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=your_account_number
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_ENV=virtual

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kis_trader

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id
GOOGLE_CREDENTIALS_PATH=credentials.json

# Rate Limit
API_RATE_LIMIT_PER_SECOND=3
API_DAILY_CALL_LIMIT=10000
WS_MAX_RECONNECT_ATTEMPTS=5
WS_RECONNECT_BASE_DELAY=5

# Trading
MAX_LOSS_RATE=0.03
MAX_POSITION_RATIO=0.2
DAILY_TRADE_LIMIT=10

# Portfolio Risk
# MAX_DAILY_DRAWDOWN=0.05
# MAX_CONSECUTIVE_LOSSES=5
# MARKET_CLOSE_CUTOFF_HOUR=14
# MARKET_CLOSE_CUTOFF_MINUTE=30

# Strategy
# STRATEGY_DEFAULT=moving_average
# STRATEGY_MAPPINGS=005930:rsi,000660:moving_average
# STRATEGY_MA_SHORT_PERIOD=5
# STRATEGY_MA_LONG_PERIOD=20
# STRATEGY_MA_MAX_DIVERGENCE=0.05
# STRATEGY_RSI_PERIOD=14
# STRATEGY_RSI_OVERSOLD=30.0
# STRATEGY_RSI_OVERBOUGHT=70.0
# STRATEGY_ENSEMBLE_METHOD=weighted
# TAKE_PROFIT_RATIO=0.05
# STRATEGY_MIN_CONFIDENCE=0.1

# Screening (종목 스크리닝)
# SCREENING_TOP_N=30
# SCREENING_INTERVAL_CYCLES=30
# MAX_SCREENED_STOCKS=10
# SCREENING_MIN_PRICE=1000
# SCREENING_MAX_PRICE=300000
# SCREENING_MIN_MARKET_CAP=50000000
# SCREENING_CHANGE_RATE_MIN=-3.0
# SCREENING_CHANGE_RATE_MAX=15.0
# SCREENING_MIN_VOLUME=50000
# SCREENING_WEIGHT_VOLUME_RANK=0.2
# SCREENING_WEIGHT_CHANGE_RATE=0.3
# SCREENING_WEIGHT_STRATEGY=0.5
# SCREENING_MIN_SCORE=0.25

# Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# TELEGRAM_ENABLED=false

# Redis
# REDIS_URL=redis://localhost:6379/0

# Worker
# WORKER_ENABLED=true
# WORKER_POLL_INTERVAL=15       # 기본값 30s는 매매 사이클(10s) 대비 느려 큐 적체 유발
# WORKER_MAX_RETRIES=5
# WORKER_RETRY_BASE_DELAY=60
# WORKER_BATCH_SIZE=50          # 기본값 10건/30s = 20건/분 처리. 매매 사이클당 ~10건
#                               # 메트릭 enqueue되므로 50/15s = 200건/분 권장.

# Docker PostgreSQL (docker-compose 전용)
POSTGRES_DB=kis_trader
POSTGRES_USER=kis
POSTGRES_PASSWORD=change_me_to_strong_password

# 포트 커스텀 (선택)
# DB_PORT=5432
# HEALTH_PORT=18923
# DASHBOARD_PORT=8501

# News Collector (데이터 수집 파이프라인 — docs/plans/2026-05-18_data-collection-pipeline.md)
# DART OpenAPI (https://opendart.fss.or.kr/) — 일 20,000건 한도
NEWS_DART_API_KEY=
# NEWS_DART_CORP_CODE_PATH=data/dart/corp_code.xml
# NEWS_DART_RATE_LIMIT_PER_SEC=1.0
# RSS 피드 설정 — config/rss_feeds.example.json 복사 후 편집
# (label/category/provider/url 구조. cp config/rss_feeds.example.json config/rss_feeds.json)
# NEWS_RSS_CONFIG_PATH=config/rss_feeds.json
# NEWS_RSS_USER_AGENT=kis-autotrader/0.1 (+contact: 운영자)
# Embedding (BGE-M3 — 1024-dim dense)
# NEWS_EMBEDDING_MODEL=BAAI/bge-m3
# NEWS_EMBEDDING_BATCH_SIZE=12
# NEWS_EMBEDDING_MAX_TOKENS=8192
# Pipeline
# NEWS_COLLECT_INTERVAL_MIN=5
# NEWS_CHUNK_RETENTION_DAYS=90
